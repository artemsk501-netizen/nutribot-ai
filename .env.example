# BotFather → @BotFather
BOT_TOKEN=
BOT_USERNAME=nutribot_ai

# Public URL (HTTPS) for webhook + Mini App
WEBHOOK_URL=
PORT=3000
MINI_APP_URL=

# SQLite — создаётся автоматически при первом запуске
SQLITE_PATH=./data/nutribot.db

# PostgreSQL (опционально вместо SQLite)
# DATABASE_URL=postgresql://nutribot:nutribot@localhost:5432/nutribot
DATABASE_URL=

# OpenAI Vision — обязателен для анализа фото (platform.openai.com/api-keys)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_CHAT_MODEL_FREE=gpt-4o-mini
OPENAI_CHAT_MODEL_PREMIUM=gpt-4o
OPENAI_MAX_IMAGE_MB=8
# OPENAI_ALLOW_MOCK=true

# USDA FoodData Central — https://fdc.nal.usda.gov/api-key-signup
USDA_API_KEY=

# Error monitoring (optional in development, recommended in production)
SENTRY_DSN=

WEBHOOK_SECRET=
ADMIN_IDS=
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_MESSAGES=25
TEST_PAYMENTS=false
NODE_ENV=development

# Еженедельные push-отчёты (воскресенье 10:00 МСК по умолчанию)
WEEKLY_REPORTS_ENABLED=true
WEEKLY_REPORT_CRON=0 10 * * 0
WEEKLY_REPORT_TZ=Europe/Moscow
# WEEKLY_REPORT_RUN_ON_START=true

# Ежедневные напоминания
DAILY_REMINDERS_ENABLED=true
DAILY_REMINDER_CRON=0 20 * * *
