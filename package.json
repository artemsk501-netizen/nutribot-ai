{
  "name": "nutribot",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram-native MVP: ИИ-трекер питания (бот + Mini App)",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && cp -r src/db/migrations dist/db/ && cp -r src/db/sqlite dist/db/ && cp -r src/data dist/ && vite build --config miniapp/vite.config.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test \"test/**/*.test.ts\"",
    "docker:up": "docker compose up -d app",
    "docker:full": "docker compose up --build"
  },
  "dependencies": {
    "@grammyjs/runner": "^2.0.3",
    "@sentry/node": "^10.53.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "grammy": "^1.35.0",
    "node-cron": "^3.0.3",
    "openai": "^4.77.0",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
